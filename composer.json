{
    "name": "uncover/modular-monolith-laravel",
    "description": "Modular monolith architecture scaffolding for Laravel",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "modular", "monolith", "scaffolding"],
    "authors": [
        {
            "name": "Uncover",
            "email": "hello@uncoverthefuture.org"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/support": "^9.0|^10.0|^11.0",
        "illuminate/console": "^9.0|^10.0|^11.0",
        "illuminate/database": "^9.0|^10.0|^11.0",
        "illuminate/http": "^9.0|^10.0|^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Uncover\\ModularMonolith\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Uncover\\ModularMonolith\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Uncover\\ModularMonolith\\Providers\\ModularServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage",
        "cs": "vendor/bin/php-cs-fixer fix --diff",
        "cs:check": "vendor/bin/php-cs-fixer fix --diff --dry-run --stop-on-violation",
        "stan": "vendor/bin/phpstan analyse --memory-limit=512M"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    }
}